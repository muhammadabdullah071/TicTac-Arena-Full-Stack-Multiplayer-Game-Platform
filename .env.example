# Database
DATABASE_URL=postgresql://tictac:tictac_password@localhost:5432/tictac_arena

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=tictac:

# Auth
AUTH_SECRET=your-256-bit-secret-change-in-production
AUTH_URL=http://localhost:5173

# Socket.io
SOCKET_PORT=3001
CORS_ORIGIN=http://localhost:5173

# Cloudinary (optional - for avatar/media uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Sentry (optional - error monitoring)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# PostHog (optional - product analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# VAPID Keys (optional - web push notifications)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@tictacarena.com
